import numpy as np
import matplotlib.pyplot as plt
from scipy.integrate import solve_ivp


# CONSTANTS
ATM   = 101325.0    # 1 atmosphere [Pa] 

# RAYLEIGH-PLESSET CONSTANTS                                        
RHO   = 998.0       # water density                         [kg/m^3]
SIGMA = 0.0728      # surface tension                       [N/m]
MU    = 1.0e-3      # dynamic viscosity                     [Pa.s]
GAMMA = 1.4         # polytropic index of the bubble gas    [no units]
P_INF = 1.0 * ATM   # ambient static pressure               [Pa]
P_V   = 2338.0      # vapour pressure of water at 20 C      [Pa]
# RAYLEIGH-PLESSET CONSTANTS

C_WATER = 1480.0    # speed of sound in water               [m/s]


# geometry of box
LX = 0.12   # box length, x  [m]  
LY = 0.07   # box width,  y  [m]


# bubble nuclei
BUBBLE_DENSITY = 1.0e6       
R0_MEAN = 5.0e-6          # mean nucleus radius  [m]
R0_STD  = (5.0/3.0)*1e-6  # standard deviation of nucleus radius  [m]
SEED    = 42              

# bacteria modelling
C_BAC       = 1.0e11          
KILL_RADIUS = 60.0e-6        
DEPTH       = 0.10            
N_CYCLES          = 3  # number of acoustic cycles per bubble
RTOL, ATOL        = 1e-4, 1e-12
USE_BLAKE_PRESCREEN = True
PRESCREEN_FACTOR    = 0.8  # this means RP only runs if P_a >= 0.8 * Blake(R0)
CAV_RATIO           = 2.0  # Rmax/R0 >= 2 for cavitation to occur

class Config:
    Lx, Ly      = LX, LY
    Pdrive_atm  = 1.7                 # peak pressure delivered at the BEST resonance
    P_threshold = 1.25                # Blake threshold
    Q           = 300                 # resonance sharpness
    M_MAX, N_MAX = 8, 8               # highest mode numbers kept in x and y
    f_lo, f_hi  = 20_000.0, 46_000.0  # range of frequencies we are using 

def mode_frequency(m, n, Lx, Ly):
    return (C_WATER / 2.0) * np.sqrt((m / Lx) ** 2 + (n / Ly) ** 2) # Resonant frequency formula
 
 
def build_modes(cfg):
    modes = []
    for m in range(cfg.M_MAX + 1):
        for n in range(cfg.N_MAX + 1):
            if m == 0 and n == 0: # Skips (0,0) as 0 half waves in x and 0 half waves in y is meaningless
                continue
            f0 = mode_frequency(m, n, cfg.Lx, cfg.Ly)
            a = 1.0 / (1.0 + m + n) # Coupling between transducer and modes, only approximation --> more accurate way is computing overlap integral but unneccessary complication 
            modes.append((m, n, f0, a))
    return modes
 
 
def mode_responses(f, cfg, modes):
    r = {}
    for (m, n, f0, a) in modes:
        gamma = f0 / cfg.Q # width of resonance peak    
        denom = np.sqrt((f0 ** 2 - f ** 2) ** 2 + (gamma * f) ** 2) # denominator of amplitude response equation for a damped, driven harmonic oscillator
        r[(m, n)] = a * f0 ** 2 / denom # numerator of amplitude response equation/denominator (split up so there isn't one really long line)
    return r # r gives how strongly each mode is responding at the driving frequency
             # these are summed later in pressure field section and act as mixing weights that
             # control how much each mode's spatial pattern contributes in the final standing wave


def response_scalar(f, cfg, modes):
    return max(mode_responses(f, cfg, modes).values())                                          
# This block of code collapses the 80 individual mode responses to give the value relating to 
# the strongest response. This is so we have a single number at each frequency that can be compared 
# against the reference maximum, letting us convert arbitrary response values into real pressure 
# in atmospheres


def reference_response(cfg, modes):
    fs = np.linspace(cfg.f_lo, cfg.f_hi, 1500)
    return max(response_scalar(f, cfg, modes) for f in fs)
# This block scans 1500 frequencies across the band, gets the strongest mode
# response at each one, then picks the single biggest value overall.
# This is the best resonance the box can produce, 
# which we set equal to Pdrive_atm when converting to real pressure.
 
 
# COMPUTING PRESSURE FIELD HERE
def pressure_field(f, cfg, modes, aref, nx=240, ny=140): # note that aref is defined later in the 
# plotting section. aref is the overall biggest value found from reference_response.
# nx and ny are number of grid points in x and y directions - 240 and 140 are enough to look
# smooth, but can be varied if need be. 

    u = np.linspace(0, 1, nx) # 0 is left wall, 1 is right wall
    v = np.linspace(0, 1, ny) # 0 is bottom wall, 1 is top wall
    U, V = np.meshgrid(u, v) # Turns the two 1-D lists into two 2-D grids. 
    # U is a 140 × 240 array where every point knows its x-position. V is a 140 × 240 array where 
    # every point knows its y-position. Together they give the coordinates of all 33,600 grid points.
    
 
    r = mode_responses(f, cfg, modes)
    S = np.zeros_like(U) # Creates a blank 140 × 240 grid, filled with zeros. 
    # This is where we put the standing wave onto. zeros_like(U) creates array with same shape as U,
    # made up of all zeros.
    
    for (m, n, f0, a) in modes:
        S += r[(m, n)] * np.cos(m * np.pi * U) * np.cos(n * np.pi * V)
        # np.cos(m * np.pi * U) computes the x-direction pattern for mode (m,n) at every grid point
        # simultaneously, and np.cos(n * np.pi * V) does the same thing in y-direction. Multiplying
        # these together gives the full 2-D spatial pattern for each mode. r[(m, n)] then 
        # multiplies this pattern by how strongly the mode is responding. S += keeps a running total,
        # so S contains the superposition of all 80 weighted patterns. Remember that near resonance
        # S looks like the corresponding mode only as its weight dominates, whereas between
        # resonances S will look messy because many modes contribute similarly.
        
    
    Smax = np.max(np.abs(S)) # finds largest value in the pattern
    Ppeak = cfg.Pdrive_atm * response_scalar(f, cfg, modes) / aref # converts to real pressure,
    # gives peak pressure that strongest point in box reaches at the drive frequency selected
    
    field = Ppeak * S / Smax if Smax > 0 else S # S/Smax squashes shape to make peak at 1,
    # then multiplying by Ppeak stretches it so peak is real pressure,
    # (basically normalised first, then Ppeak stamps the real scale on).
 
    X = U * cfg.Lx * 100.0 # * 100 converts to cm                         
    Y = V * cfg.Ly * 100.0
    return X, Y, field, Ppeak, Smax
 

# BUBBLE NUCLEI GENERATOR GAUSSIAN
def generate_bubbles(length, width, density, r0_mean, r0_std, seed=None):
    rng = np.random.default_rng(seed)

    spacing = 1.0 / np.sqrt(density)       
    nx = int(np.floor(length / spacing))
    ny = int(np.floor(width  / spacing))
    N = nx * ny

    xc = (np.arange(nx) + 0.5) * spacing    # centralises so never on a wall
    yc = (np.arange(ny) + 0.5) * spacing
    X, Y = np.meshgrid(xc, yc)
    x, y = X.ravel(), Y.ravel()

    R0 = rng.normal(r0_mean, r0_std, size=N)
    R0[R0 < 0] = 0.0    # negative draw -> empty site
    return x, y, R0, spacing


# RAYLEIGH-PLESSET AND CAVITATION TEST
def blake_threshold(R0):
    p0   = P_INF - P_V
    p_g0 = p0 + 2 * SIGMA / R0
    R_c  = np.sqrt(3 * p_g0 * R0 ** 3 / (2 * SIGMA))
    p_Lmin = p_g0 * (R0 / R_c) ** 3 - 2 * SIGMA / R_c
    return p0 - p_Lmin


def simulate_bubble(R0, P_a, f_drive, n_cycles=N_CYCLES):
    omega = 2 * np.pi * f_drive
    p_g0  = P_INF - P_V + 2 * SIGMA / R0

    def rhs(t, y):
        R, Rdot = y
        if R < 0.01 * R0:
            R = 0.01 * R0
        p_g   = p_g0 * (R0 / R) ** (3 * GAMMA)
        p_ext = P_INF - P_a * np.sin(omega * t)
        Rddot = ((p_g - p_ext) / RHO
                 - 2 * SIGMA / (RHO * R)
                 - 4 * MU * Rdot / (RHO * R)
                 - 1.5 * Rdot ** 2) / R
        return [Rdot, Rddot]

    def collapse_event(t, y): # THIS IS NEW, IT FIXES ERROR
        return y[0] - 0.05 * R0    # triggers when R crosses 0.05*R0
    collapse_event.terminal = True    # integration stops here
    collapse_event.direction = -1    # only when bubble collapses

    t_span = (0.0, n_cycles / f_drive)
    t_eval = np.linspace(*t_span, 1500)
    return solve_ivp(rhs, t_span, [R0, 0.0], method='LSODA', # uses LSODA from SciPy to solve Rayleigh-Plesset equation
                     t_eval=t_eval, rtol=RTOL, atol=ATOL,
                     events=collapse_event)


def classify_cavitation(R_trace, R0, ratio=CAV_RATIO):
    Rmax, Rmin = R_trace.max(), R_trace.min()
    return (Rmax >= ratio * R0), Rmax, Rmin

def run_at_frequency(f, cfg, modes, aref, x, y, R0, P_blake, detailed=False): 
    _, _, _, Ppeak, Smax = pressure_field(f, cfg, modes, aref) 
    scale = Ppeak / Smax * ATM if Smax > 0 else 0.0   # atm -> Pa

    # finds local pressure at every bubble
    r  = mode_responses(f, cfg, modes)
    Pa = np.zeros(len(x))
    for (m, n, _, _) in modes:
        Pa += r[(m, n)] * np.cos(m * np.pi * x / LX) * np.cos(n * np.pi * y / LY)
    Pa = np.abs(scale * Pa)

    # checks for our assumed blake threshold condition
    passes = Pa >= PRESCREEN_FACTOR * P_blake

    if not detailed:
        return int(np.sum(passes))             

    # runs Rayleigh-Plesset for every bubble that passes
    is_cav  = np.zeros(len(x), dtype=bool)
    Rmax_arr = np.zeros(len(x))
    Rmin_arr = np.zeros(len(x))

    for i in np.where(passes & (R0 > 0))[0]:
        sol = simulate_bubble(R0[i], Pa[i], f)
        if sol.success:
            cav, Rmax, Rmin = classify_cavitation(sol.y[0], R0[i])
            is_cav[i]   = cav
            Rmax_arr[i] = Rmax
            Rmin_arr[i] = Rmin

    return {
        'x': x, 'y': y, 'R0': R0, 'Pa': Pa,
        'is_cav': is_cav, 'Rmax': Rmax_arr, 'Rmin': Rmin_arr,
        'Ppeak': Ppeak, 'f': f
    }

def build_sweep_grid(modes, f_lo, f_hi, dense_half=200.0, dense_step=10.0, sparse_step=500.0):
    mode_freqs = sorted(set(f0 for (_, _, f0, _) in modes if f_lo <= f0 <= f_hi))

    grid = set(np.arange(f_lo, f_hi, sparse_step))
    for fm in mode_freqs:                                   
        dense = np.arange(fm - dense_half, fm + dense_half, dense_step)
        grid.update(dense[(dense >= f_lo) & (dense <= f_hi)])

    return np.array(sorted(grid))


cfg   = Config()
modes = build_modes(cfg)
aref  = reference_response(cfg, modes)
x, y, R0, spacing = generate_bubbles(LX, LY, BUBBLE_DENSITY, R0_MEAN, R0_STD, SEED)
P_blake = np.array([blake_threshold(r) if r > 0 else np.inf for r in R0])

# sorts out frequency sweep 
freqs  = build_sweep_grid(modes, cfg.f_lo, cfg.f_hi)
counts = [run_at_frequency(f, cfg, modes, aref, x, y, R0, P_blake, detailed=False)
          for f in freqs]
f_best = freqs[np.argmax(counts)]
print(f"Sweep done: {len(freqs)} frequencies, best = {f_best:.0f} Hz "
      f"({max(counts)} bubbles past Blake)")

# this computes full run at the best frequency
results = run_at_frequency(f_best, cfg, modes, aref, x, y, R0, P_blake, detailed=True)
n_cav = int(np.sum(results['is_cav']))
print(f"Full RP at {f_best:.0f} Hz: {n_cav} inertially cavitating out of {len(R0)}")

# Pressure field heatmap/graph
X, Y, field, Ppeak, Smax = pressure_field(f_best, cfg, modes, aref)
plt.figure()
plt.pcolormesh(X, Y, field, cmap='RdBu_r', shading='auto')
plt.colorbar(label='Pressure amplitude [atm]')
plt.xlabel('x [cm]')
plt.ylabel('y [cm]')
plt.title(f'Pressure field at {f_best:.0f} Hz')
plt.tight_layout()
plt.show()

# Response against frequency graph 
freq_range = np.linspace(cfg.f_lo, cfg.f_hi, 1000)
resp = [response_scalar(f, cfg, modes) for f in freq_range]
plt.figure()
plt.plot(freq_range / 1e3, resp)
plt.xlabel('Frequency [kHz]')
plt.ylabel('Response (a.u.)')
plt.title('Cavity response vs driving frequency')
plt.tight_layout()
plt.show()

# Radius of bubble over time for single bubble
cav_mask = results['is_cav'] & (results['R0'] > 0)
cav_indices = np.where(cav_mask)[0]
i_pick = cav_indices[np.argmax(results['Pa'][cav_indices])]
sol = simulate_bubble(results['R0'][i_pick], results['Pa'][i_pick], f_best)
plt.figure()
plt.plot(sol.t * 1e6, sol.y[0] / results['R0'][i_pick])
plt.xlabel('Time [µs]')
plt.ylabel('R / R₀')
plt.title(f'Bubble dynamics (R₀={results["R0"][i_pick]*1e6:.1f} µm)')
plt.tight_layout()
plt.show()

# Cavitation map - shows where cavitation occurs in our tank at best frequency 
cav = results['is_cav']
plt.figure()
plt.scatter(results['x'][~cav]*100, results['y'][~cav]*100,
            s=1, c='grey', alpha=0.3, label='No cavitation')
plt.scatter(results['x'][cav]*100, results['y'][cav]*100,
            s=3, c='red', label='Cavitating')
plt.xlabel('x [cm]')
plt.ylabel('y [cm]')
plt.title(f'Cavitation map at {f_best:.0f} Hz')
plt.legend()
plt.tight_layout()
plt.show()
 
